# Server Configuration
PORT=3000
NODE_ENV=development

# Email Configuration - Gmail OAuth2 (Recommended for Production)
# Get these from Google Cloud Console
OAUTH_CLIENT_ID=your_oauth_client_id_here
OAUTH_CLIENT_SECRET=your_oauth_client_secret_here
OAUTH_REFRESH_TOKEN=your_oauth_refresh_token_here
OAUTH_EMAIL=topviewpublicschool@gmail.com

# Email Configuration - Gmail SMTP (Fallback)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=topviewpublicschool@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM=Top View Public School <topviewpublicschool@gmail.com>

# Portfolio Owner Info
OWNER_NAME=Rohan Srivastava
