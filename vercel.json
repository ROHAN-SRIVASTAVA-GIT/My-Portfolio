{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["index.html", "css/**", "js/**", "lib/**", "img/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/contact",
      "dest": "/server.js",
      "methods": ["POST"]
    },
    {
      "src": "/api/health",
      "dest": "/server.js",
      "methods": ["GET"]
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
